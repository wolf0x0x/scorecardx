# ScorecardX local data sync configuration.
# Copy to .env or export these variables in your shell/launchd environment.

# API-Sports / API-Football
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# API-Sports Cricket
APISPORTS_CRICKET_KEY=
APISPORTS_CRICKET_BASE_URL=https://v1.cricket.api-sports.io

# Basketball provider. BallDontLie is optional; ESPN NBA is used as the no-key fallback.
# Set BALLDONTLIE_API_KEY if your BallDontLie account/plan requires one.
BALLDONTLIE_API_KEY=

# Optional fallback/extra feeds
ENTITY_SPORT_KEY=
OPENF1_BASE_URL=https://api.openf1.org/v1
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# Automation
SCORECARDX_REMOTE=origin
SCORECARDX_BRANCH=main
SCORECARDX_COMMIT_PREFIX=data
